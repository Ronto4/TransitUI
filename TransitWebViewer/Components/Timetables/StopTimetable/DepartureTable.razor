@using Timetable
@using Timetable.Views
@using TransitWebViewer.Utils

<table class="table table-striped table-hover">
    <thead>
    <tr>
        <th scope="col">
            🕐
        </th>
        @if (StopTimetableView.ValidityMode is ValidityMode.Regular)
        {
            @foreach (var (days, index) in StopTimetableView.DaysPartition.Select((days, index) => (days, index)))
            {
                <th scope="col" colspan="@StopTimetableView.MaximumColumns.ElementAt(index)" class="@days.CssColor()">
                    @days.Display()
                </th>
            }
        }
        else
        {
            <th scope="col" colspan="@StopTimetableView.MaximumColumns.Max()">
                @StopTimetableView.DayOfTimetable.ToString("D")
            </th>
        }
    </tr>
    </thead>
    <tbody>
    @foreach (var (hour, info) in StopTimetableView.HourInfos)
    {
        <DepartureHour Hour="hour" HourInfo="info" StopTimetableView="StopTimetableView" />
    }
    </tbody>
</table>

@code {
    [Parameter, EditorRequired] public required StopTimetableView StopTimetableView { get; init; }
}
